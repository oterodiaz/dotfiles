if status is-interactive
  set -g fish_greeting
  fish_config theme choose kanagawa

  # Prompt
  if command -v starship &> /dev/null
    source (starship init fish --print-full-init | psub)
  end

  # Aliases
  alias diff='diff --color=auto'
  alias grep='grep --color=auto'

  {{- if eq .chezmoi.os "darwin" }}
  alias localip='ipconfig getifaddr en0'
  {{- else }}
  alias localip='hostname -I'
  alias ip='ip -color=auto'
  {{- end }}

  if command -v eza &> /dev/null
    alias ls='eza --group-directories-first --icons --sort=name --no-time --git'
    alias ll='eza -l --group-directories-first --icons --sort=name --no-time --git'
    alias la='eza -la --group-directories-first --icons --sort=name --no-time --git'
    alias tree='eza --group-directories-first --icons --sort=name --no-time --git -T'
  else
    alias ls='ls --color=auto'
    alias ll='ls --color=auto -l'
    alias la='ls --color=auto -la'
  end

  if command -v bat &> /dev/null
    alias bat='bat --theme ansi'
    alias cat='bat -pP'
  end

  if command -v nvim &> /dev/null
    abbr -g 'vim' 'nvim'
    abbr -g 'vi' 'nvim'
  end

  # Keybindings
  set -g fish_key_bindings fish_vi_key_bindings
  bind -M insert \cf forward-char
  bind -M insert \cr history-pager
  bind -M default \x20 edit_command_buffer # \x20 -> spacebar
end
